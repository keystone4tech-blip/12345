# ==============================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ ДЛЯ ПРОЕКТА
# ==============================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#   nano .env
# ==============================================================

# ============================================
# БАЗА ДАННЫХ (PostgreSQL)
# ============================================
POSTGRES_DB=jarvis_vpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_НАДЁЖНЫЙ_ПАРОЛЬ

# ============================================
# ПОРТЫ СЕРВИСОВ
# ============================================
# Порт веб-API бота (healthcheck, кабинет API)
BOT_API_PORT=8080

# Порт кабинета (фронтенд)
CABINET_PORT=3020

# ============================================
# КАБИНЕТ (build-time переменные)
# ============================================
# URL API бота для кабинета
# Если бот и кабинет на одном сервере: http://bot:8080/cabinet
# Если на разных серверах: https://api.yourdomain.com/cabinet
VITE_API_URL=http://bot:8080/cabinet

# Telegram bot username (без @)
VITE_TELEGRAM_BOT_USERNAME=Jarvis_VPN_Robot

# Имя приложения (отображается в шапке кабинета)
VITE_APP_NAME=Jarvis VPN Cabinet

# Короткий логотип (1-2 символа)
VITE_APP_LOGO=MV
